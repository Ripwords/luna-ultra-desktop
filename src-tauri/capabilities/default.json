{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "updater:default",
    "process:default",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$DOWNLOAD/**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$DOWNLOAD/**" }]
    },
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://**" }]
    }
  ]
}
